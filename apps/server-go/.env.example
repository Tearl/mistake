# —— 本地开发（默认值即可跑）——
DATABASE_URL=postgres://zhaoyu@localhost:5432/mistake?sslmode=disable
DASHSCOPE_API_KEY=            # 阿里云百炼 key；留空则识别/举一反三返回 503
CORS_ORIGIN=http://localhost:3001   # 逗号分隔白名单
PORT=3000
API_KEY=                     # 留空=本地不校验；生产填共享密钥（前端同值）

# —— 图片存储 ——
STORAGE=local                # local | s3
UPLOAD_DIR=uploads           # local 用
PUBLIC_BASE_URL=http://localhost:3000   # local 用：拼图片 URL

# —— 生产（STORAGE=s3 时用；本地留空）——
S3_BUCKET=
AWS_REGION=
S3_PUBLIC_BASE_URL=          # 留空则用 https://<bucket>.s3.<region>.amazonaws.com
