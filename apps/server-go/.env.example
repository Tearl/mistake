# —— 本地开发（默认值即可跑）——
DATABASE_URL=postgres://zhaoyu@localhost:5432/mistake?sslmode=disable
DASHSCOPE_API_KEY=            # 阿里云百炼 key；留空则识别/举一反三返回 503
CORS_ORIGIN=http://localhost:3001   # 逗号分隔白名单
PORT=3000
API_KEY=                     # 留空=本地不校验；生产填共享密钥（前端同值）

# —— 图片存储 ——
STORAGE=local                # local | s3
UPLOAD_DIR=uploads           # local 用
PUBLIC_BASE_URL=http://localhost:3000   # local 用：拼图片 URL

# —— 生产（STORAGE=s3 时用；本地留空）——
S3_BUCKET=
AWS_REGION=
S3_PUBLIC_BASE_URL=          # 留空则用 https://<bucket>.s3.<region>.amazonaws.com

# —— 运行模式 / SNS + SQS 异步识别 ——
APP_MODE=api                 # api | worker | all | migrate
AUTO_MIGRATE=true            # 本地 true；生产先跑 migrate task 后将 API/Worker 设为 false
ASYNC_RECOGNITION=false      # 本地 false：新任务接口同步执行；生产 true：发布 SNS
SNS_TOPIC_ARN=               # APP_MODE=api/all 且开启异步时必填
SQS_QUEUE_URL=               # APP_MODE=worker/all 时必填
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=120
SQS_MAX_RECEIVE_COUNT=3      # 必须与 SQS RedrivePolicy.maxReceiveCount 一致

# —— Canary / 版本探针 ——
APP_VERSION=dev              # 生产填不可变 Git SHA
BUILD_TIME=unknown           # ISO-8601 构建时间
