{
  "name": "mistake",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "check-types": "npm run check-types --workspaces --if-present",
    "dev:web": "npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "db:push": "npm run db:push --workspace @mistake/db",
    "db:studio": "npm run db:studio --workspace @mistake/db",
    "db:generate": "npm run db:generate --workspace @mistake/db",
    "db:migrate": "npm run db:migrate --workspace @mistake/db",
    "deploy": "npm run deploy --workspace @mistake/infra",
    "destroy": "npm run destroy --workspace @mistake/infra"
  },
  "dependencies": {
    "@mistake/env": "*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@mistake/config": "*",
    "@types/node": "^22.13.14",
    "typescript": "^6"
  },
  "packageManager": "npm@11.16.0"
}
