{
  "family": "mistake-migrate",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": { "cpuArchitecture": "ARM64", "operatingSystemFamily": "LINUX" },
  "executionRoleArn": "arn:aws:iam::__ACCOUNT__:role/mistake-ecs-exec-role",
  "taskRoleArn": "arn:aws:iam::__ACCOUNT__:role/mistake-task-role",
  "containerDefinitions": [{
    "name": "migrate",
    "image": "__IMAGE__",
    "essential": true,
    "environment": [
      { "name": "APP_MODE", "value": "migrate" },
      { "name": "AUTO_MIGRATE", "value": "true" }
    ],
    "secrets": [
      { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT__:parameter/mistake/DATABASE_URL" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": { "awslogs-group": "/ecs/mistake", "awslogs-region": "__REGION__", "awslogs-stream-prefix": "migrate" }
    }
  }]
}
